# ============================================================
# PLACEMAT — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Server
PORT=5000
NODE_ENV=development

# JWT — CHANGE THIS TO A LONG RANDOM SECRET IN PRODUCTION!
JWT_SECRET=placemat_super_secret_change_this_in_production_2025_scsit_davv
JWT_EXPIRES_IN=7d

# Database path (relative to backend root)
DB_PATH=./database/placemat.db

# File uploads
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=5242880

# Path to the frontend folder (relative to backend/placemat-backend)
FRONTEND_DIR=../../frontend/placemat-frontend

# Security
BCRYPT_ROUNDS=12

# Email verification flow
EMAIL_VERIFICATION_EXP_MINUTES=15
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60

# SMTP (required for sending verification emails)
# Example (Gmail/Workspace with app password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email@example.com
# SMTP_PASS=your_app_password
# SMTP_FROM=PlaceMate <no-reply@example.com>
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Groq chatbot
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Production only: your deployed domain
# ALLOWED_ORIGIN=https://yourdomain.com
